# Where API resolvers prepend their relative endpoints. Leave blank for
# fully-qualified URLs in your form configs.
API_BASE_URL=http://localhost

# Where the gravityForms adapter POSTs the submitGfForm mutation.
FORM_API_ENDPOINT=http://localhost/your-wp-site/graphql

# Toggle verbose orchestration logs in the server terminal.
# 1 = on, 0 = off, omitted = on in dev / off in prod.
FORM_ORCHESTRATOR_DEBUG=1
